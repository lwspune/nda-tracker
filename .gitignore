# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Faculty exam data — written by the Vite dev plugin, contains sensitive exam data
data/faculty-data.json

# Student DB — single source of truth is public/data/db.json (copied to dist/ by vite automatically)
data/db.json
students_db.json

# Teacher password — plain text, hashed by split_students.py into public/data/teacher-auth.json
teacher_password.txt

# Gmail App Password — used by send_results.py
gmail_app_password.txt

# WhatsApp send log — contains full API credentials in every entry
whatsapp_send_log.jsonl

# HTML preview files generated by send_results.py --dry-run
preview_*.html

# Student contact export generated on demand — contains personal data
students_contact_list.xlsx

# Generated by split_students.py — rebuilt on every deploy
public/data/
db.json

# Python bytecode
__pycache__/
*.pyc

# Supabase MCP config — contains personal access token
.mcp.json

